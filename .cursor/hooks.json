{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "python .cursor/hooks/session_start.py",
        "timeout": 15
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "python .cursor/hooks/validate_runtime_header.py",
        "timeout": 10,
        "failClosed": true
      },
      {
        "command": "python .cursor/hooks/check_model_tier.py",
        "timeout": 10
      }
    ],
    "preToolUse": [
      {
        "command": "python .cursor/hooks/guard_mode_before_edit.py",
        "matcher": "Write|StrReplace|Delete|Edit",
        "timeout": 10,
        "failClosed": true
      }
    ],
    "preCompact": [
      {
        "command": "python .cursor/hooks/log_model_context.py",
        "timeout": 10
      }
    ],
    "sessionEnd": [
      {
        "command": "python .cursor/hooks/log_model_context.py",
        "timeout": 10
      }
    ]
  }
}
