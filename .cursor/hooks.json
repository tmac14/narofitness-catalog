{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "py -3 .cursor/hooks/session_start.py",
        "timeout": 15
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "py -3 .cursor/hooks/validate_runtime_header.py",
        "timeout": 10,
        "failClosed": true
      }
    ],
    "preToolUse": [
      {
        "command": "py -3 .cursor/hooks/guard_mode_before_edit.py",
        "matcher": "Write|StrReplace|Delete|Edit",
        "timeout": 10,
        "failClosed": true
      }
    ]
  }
}
