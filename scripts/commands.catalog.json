        {
          "name": "db:seed:stress:fresh",
          "description": "Borra datos stress y regenera.",
          "requires": [
            "Docker levantado"
          ],
          "examples": [
            "npm run db:seed:stress:fresh"
          ],
          "related": [
            "db:seed:stress"
          ]
