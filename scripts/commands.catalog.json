    {
      "id": "tunnel",
      "title": "Demo remota (Cloudflare)",
      "notes": [
        "Requisito: API local en :8000 (npm run docker:up).",
        "Estado en temp/cloudflare-tunnels/state.json. Requiere cloudflared instalado."
      ],
      "commands": [
        {
          "name": "tunnel:start",
          "description": "Tunnel público API + UI. Vite en :3014 por defecto. Sin Electron.",
          "requires": [
            "npm run docker:up",
            "cloudflared instalado"
          ],
          "examples": [
            "npm run tunnel:start",
            "npm run tunnel:start -- -KeepDev",
            "npm run tunnel:start -- -UiPort 4014",
            "npm run tunnel:start -- -StopAllTunnels"
          ],
          "underlyingScript": "scripts/tunnel-start.ps1",
          "flags": [
            {
              "name": "-UiPort",
              "default": "3014",
              "description": "Puerto local de Vite"
            },
            {
              "name": "-TimeoutSeconds",
              "default": "45",
              "description": "Timeout de arranque"
            },
            {
              "name": "-KeepDev",
              "description": "No detiene npm run dev / dev:app / dev:web en :5173"
            },
            {
              "name": "-StopAllTunnels",
              "description": "También mata otros cloudflared del workspace (por defecto se conservan)"
            }
          ],
          "related": [
            "tunnel:stop",
            "docker:up",
            "frontend:stop"
          ]
        },
        {
          "name": "tunnel:stop",
          "description": "Detiene tunnels Narofitness y frontend; limpia temp/cloudflare-tunnels/state.json. Conserva otros cloudflared por defecto.",
          "examples": [
            "npm run tunnel:stop",
            "npm run tunnel:stop -- -StopAllTunnels"
          ],
          "underlyingScript": "scripts/tunnel-stop.ps1",
          "flags": [
            {
              "name": "-StopAllTunnels",
              "description": "También mata otros cloudflared del workspace"
            }
          ],
          "related": [
            "tunnel:start",
            "frontend:stop"
          ]
        }
      ]
    },
