{
  "meta": {
    "version": 1,
    "locale": "es"
  },
  "quickFlows": [
    {
      "goal": "Primera instalación",
      "command": "setup"
    },
    {
      "goal": "Desarrollo diario (Electron)",
      "command": "dev"
    },
    {
      "goal": "Desarrollo en navegador",
      "command": "dev:web"
    },
    {
      "goal": "Reset BD + PDF + app",
      "command": "dev:fresh"
    },
    {
      "goal": "Demo remota (tunnel)",
      "command": "docker:up → tunnel:start",
      "commands": [
        "docker:up",
        "tunnel:start"
      ]
    },
    {
      "goal": "Tests API unitarios",
      "command": "test:api"
    },
    {
      "goal": "Instalador Windows",
      "command": "pack:release"
    }
  ],
  "localUrls": {
    "api": "http://127.0.0.1:8000/docs",
    "ui": "http://127.0.0.1:5173",
    "postgresHostPort": 5433
  },
  "sections": [
    {
      "id": "dev",
      "title": "Desarrollo",
      "commands": [
        {
          "name": "dev",
          "description": "Docker (si hace falta) + Vite + Electron. Omite up si postgres+api ya responden. No aplica migraciones.",
          "examples": [
            "npm run dev"
          ],
          "underlyingScript": "scripts/desktop-run-local.ps1",
          "related": [
            "dev:web",
            "docker:up",
            "frontend:app"
          ]
        },
        {
          "name": "dev:web",
          "description": "Igual que dev pero solo Vite en navegador (sin Electron).",
          "examples": [
            "npm run dev:web"
          ],
          "underlyingScript": "scripts/desktop-run-local.ps1",
          "flags": [
            {
              "name": "-WebOnly",
              "description": "Pasado internamente por el script PowerShell"
            }
          ],
          "related": [
            "dev",
            "frontend:web"
          ]
        },
        {
          "name": "dev:fresh",
          "description": "Reset BD completo + import PDF + arranque Electron. Requiere PDF en temp/FDL .. Tarifa Mayorista 01-Febr-2026.pdf.",
          "requires": [
            "PDF en temp/",
            "Docker en ejecución"
          ],
          "examples": [
            "npm run dev:fresh"
          ],
          "underlyingScript": "scripts/dev-fresh.ps1",
          "related": [
            "dev:fresh:wipe",
            "db:reset:full"
          ]
        },
        {
          "name": "dev:fresh:wipe",
          "description": "Igual que dev:fresh pero borra volumen PostgreSQL.",
          "requires": [
            "PDF en temp/",
            "Docker en ejecución"
          ],
          "examples": [
            "npm run dev:fresh:wipe"
          ],
          "underlyingScript": "scripts/dev-fresh.ps1",
          "flags": [
            {
              "name": "-WipeDatabase",
              "description": "Borra volumen pgdata"
            }
          ],
          "related": [
            "dev:fresh",
            "db:reset:full:wipe"
          ]
        },
        {
          "name": "setup",
          "description": "Primera vez: docker:up → db:migrate → db:seed:pim → db:seed:fresh → desktop:install.",
          "examples": [
            "npm run setup"
          ],
          "related": [
            "docker:up",
            "db:migrate",
            "desktop:install"
          ]
        },
        {
          "name": "frontend:app",
          "description": "Solo Vite + Electron (asume Docker ya arriba).",
          "examples": [
            "npm run frontend:app"
          ],
          "related": [
            "dev",
            "docker:up"
          ]
        },
        {
          "name": "frontend:web",
          "description": "Solo Vite en :5173.",
          "examples": [
            "npm run frontend:web"
          ],
          "related": [
            "dev:web"
          ]
        },
        {
          "name": "frontend:stop",
          "description": "Detiene Vite, Electron y cloudflared del proyecto.",
          "examples": [
            "npm run frontend:stop"
          ],
          "underlyingScript": "scripts/stop-narofitness-frontend.ps1",
          "related": [
            "tunnel:stop"
          ]
        },
        {
          "name": "desktop:install",
          "description": "npm ci en apps/desktop.",
          "examples": [
            "npm run desktop:install"
          ],
          "related": [
            "setup"
          ]
        },
        {
          "name": "desktop:build",
          "description": "Delegado a build en apps/desktop.",
          "examples": [
            "npm run desktop:build"
          ],
          "related": [
            "pack:release"
          ]
        },
        {
          "name": "desktop:electron",
          "description": "Delegado a electron en apps/desktop (UI buildeada).",
          "examples": [
            "npm run desktop:electron"
          ],
          "related": [
            "desktop:build"
          ]
        }
      ]
    },
    {
      "id": "docker",
      "title": "Docker",
      "notes": [
        "Si aparece mkdir /run/desktop/mnt/host/f: file exists: npm run docker:down && npm run docker:rebuild:prod",
        "Para hot-reload en unidad F: compartir F: en Docker Desktop → File sharing → npm run docker:up"
      ],
      "commands": [
        {
          "name": "docker:up",
          "description": "Postgres + API con hot-reload (docker-compose.dev.yml, bind mount ./apps/api).",
          "profile": "Dev (default)",
          "examples": [
            "npm run docker:up"
          ],
          "related": [
            "docker:down",
            "dev"
          ]
        },
        {
          "name": "docker:up:prod",
          "description": "Imagen fija, sin bind mount. Usar si falla mount en unidad F:.",
          "profile": "Prod-like",
          "examples": [
            "npm run docker:up:prod"
          ],
          "related": [
            "docker:rebuild:prod"
          ]
        },
        {
          "name": "docker:down",
          "description": "Para contenedores (no borra volúmenes).",
          "profile": "Dev",
          "examples": [
            "npm run docker:down"
          ],
          "related": [
            "docker:up"
          ]
        },
        {
          "name": "docker:restart",
          "description": "Reinicia contenedor api.",
          "profile": "Dev",
          "examples": [
            "npm run docker:restart"
          ],
          "related": [
            "docker:up"
          ]
        },
        {
          "name": "docker:rebuild",
          "description": "Rebuild API sin caché + docker:up.",
          "profile": "Dev",
          "examples": [
            "npm run docker:rebuild"
          ],
          "related": [
            "docker:up"
          ]
        },
        {
          "name": "docker:rebuild:prod",
          "description": "Rebuild sin bind mount.",
          "profile": "Prod-like",
          "examples": [
            "npm run docker:rebuild:prod"
          ],
          "related": [
            "docker:up:prod"
          ]
        },
        {
          "name": "docker:logs",
          "description": "Logs en tiempo real (todos los servicios).",
          "profile": "Dev",
          "examples": [
            "npm run docker:logs"
          ],
          "related": [
            "docker:logs:api"
          ]
        },
        {
          "name": "docker:logs:api",
          "description": "Solo logs API.",
          "profile": "Dev",
          "examples": [
            "npm run docker:logs:api"
          ],
          "related": [
            "docker:logs"
          ]
        }
      ]
    },
    {
      "id": "db",
      "title": "Base de datos",
      "notes": [
        "Requisito: contenedores Docker levantados."
      ],
      "commands": [
        {
          "name": "db:migrate",
          "description": "alembic upgrade head en contenedor API.",
          "requires": [
            "Docker levantado"
          ],
          "examples": [
            "npm run db:migrate"
          ],
          "related": [
            "db:revision",
            "setup"
          ]
        },
        {
          "name": "db:revision",
          "description": "Nueva migración autogenerada.",
          "requires": [
            "Docker levantado"
          ],
          "examples": [
            "npm run db:revision -- \"mensaje\""
          ],
          "flags": [
            {
              "name": "mensaje",
              "description": "Argumento posicional tras -- (texto de la revisión Alembic)"
            }
          ],
          "related": [
            "db:migrate"
          ]
        },
        {
          "name": "db:seed:pim",
          "description": "Taxonomía, specs, perfiles, reglas de mapeo PIM.",
